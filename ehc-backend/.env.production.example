# ──────────────────────────────────────────────────────────────────────────────
# Backend production env (Railway / any Node host)
# Copy these names into your hosting provider's env-var UI. Never commit real values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Node runtime ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000               # Railway sets PORT automatically; leave or override

# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# DATABASE_URL  → transaction pool (port 6543) — used at runtime
# DIRECT_URL    → direct connection (5432) — used by Prisma migrations only
DATABASE_URL=postgresql://USER:PASS@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20
DIRECT_URL=postgresql://USER:PASS@HOST.pooler.supabase.com:5432/postgres

# ── Supabase auth ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
# JWKS-based JWT verification — no JWT_SECRET needed.

# ── Tenant ────────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=ehc_xxxxxxxxxxxxxxxxxxxx

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=hello@everlastinghills.org
RESEND_ADMIN_EMAIL=admin@everlastinghills.org
CONTACT_EMAIL=contact@everlastinghills.org

# ── CORS ──────────────────────────────────────────────────────────────────────
# REQUIRED in production. Set to your main frontend URL.
FRONTEND_URL=https://everlastinghills.org

# Optional: comma-separated extra origins (staging URLs, custom domains).
# Vercel preview URLs (*.vercel.app) are auto-allowed unless you set
# CORS_ALLOW_VERCEL_PREVIEWS=false.
# CORS_EXTRA_ORIGINS=https://staging.everlastinghills.org,https://ehc-staging.example.com
# CORS_ALLOW_VERCEL_PREVIEWS=true

# ── Rate limiting (optional — defaults shown) ─────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
