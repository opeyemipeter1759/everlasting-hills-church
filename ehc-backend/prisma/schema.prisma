/// Authoritative usher headcount: one aggregate count per service. Source of
/// truth for congregation size and all growth / attendance-trend analytics.
/// Distinct from AttendanceRecord (per-person check-ins), which stays as-is and
/// powers per-member metrics only. Tenant-scoped in the service layer (@Roles +
/// tenantId); RLS deny-all backstop via prisma/manual SQL.
model ServiceHeadcount {
  id            String          @id
  tenantId      String
  serviceId     String          @unique
  recordedBy    String? // authenticated principal id (no FK; mirrors AuditLog.actorId)
  men           Int             @default(0)
  women         Int             @default(0)
  boys          Int             @default(0)
  girls         Int             @default(0)
  firstTimers   Int             @default(0)
  total         Int             @default(0) // service-computed = men+women+boys+girls; DB CHECK guards it
  reportedTotal Int? // optional usher-reported total, for reconciliation only
  notes         String?
  status        HeadcountStatus @default(DRAFT)
  recordedAt    DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  Service       Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  Tenant        Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

