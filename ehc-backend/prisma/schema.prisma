  ContactMessage     ContactMessage[]
  DiscussionQuestion DiscussionQuestion[]
  DiscussionResponse DiscussionResponse[]
  EmailSubscriber    EmailSubscriber[]
  EngagementScore    EngagementScore[]
  Event              Event[]
  EventRsvp          EventRsvp[]
  FollowUpTask       FollowUpTask[]
  FormSubmission     FormSubmission[]
  GivingRecord       GivingRecord[]
  Household          Household[]
  InventoryItem      InventoryItem[]
  InventoryHistory   InventoryHistory[]
  KnownDevice        KnownDevice[]
  ListenProgress     ListenProgress[]
  Member             Member[]
  Notification       Notification[]
  PastorNote         PastorNote[]
  PastoralAlert      PastoralAlert[]
  PaystackWebhookLog PaystackWebhookLog[]
  PrayerRequest      PrayerRequest[]
  RoleAssignment     RoleAssignment[]
  Sermon             Sermon[]
  SermonBookmark     SermonBookmark[]
  SermonComment      SermonComment[]
  SermonDirectMessage SermonDirectMessage[]
  SermonEpisode      SermonEpisode[]
  SermonNote         SermonNote[]
  SermonReaction     SermonReaction[]
  Service            Service[]
  ServiceHeadcount   ServiceHeadcount[]
  Department         Department[]
  DepartmentHead     DepartmentHead[]
  RoleGrant          RoleGrant[]
  UnitLeadAssignment UnitLeadAssignment[]
  HeadUsherAssignment HeadUsherAssignment[]
  SiteSettings       SiteSettings[]
  Testimonial        Testimonial[]
  Unit               Unit[]
  Visitor            Visitor[]
}

/// Church-owned physical assets: equipment, furniture, AV/media gear, vehicles,
/// facilities, instruments, kitchen and office items. History is the single
/// chronological log of everything that's happened to an item (purchase + repairs).
model InventoryItem {
  id            String              @id
  tenantId      String
  name          String
  category      String
  serialNumber  String?
  location      String?
  status        InventoryStatus     @default(IN_USE)
  condition     InventoryCondition  @default(NEW)
  quantity      Int                 @default(1)
  purchaseDate  DateTime?
  purchaseValue Float?
  assignedTo    String?
  photoUrl      String?
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  History       InventoryHistory[]
  Tenant        Tenant              @relation(fields: [tenantId], references: [id])

  @@index([tenantId, category])
  @@index([tenantId, status])
}

/// One row per lifecycle event for an item — the first is always type NEW
/// (created alongside the item), every repair logged afterward adds a REPAIR row.
model InventoryHistory {
  id           String                @id
  tenantId     String
  itemId       String
  type         InventoryHistoryType
  description  String? // NEW: optional note. REPAIR: what was wrong.
  resolution   String? // REPAIR only: what was done to fix it.
  cost         Float?
  performedBy  String?
  repairStatus RepairStatus?
  occurredAt   DateTime              @default(now())
  createdAt    DateTime              @default(now())
  Item         InventoryItem         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  Tenant       Tenant                @relation(fields: [tenantId], references: [id])

  @@index([tenantId, itemId, occurredAt])
}

model Event {
  id              String      @id
  tenantId        String
  slug            String
  title           String
  tagline         String?
  description     String?
  startAt         DateTime
  endAt           DateTime?
  venueName       String?
  venueAddress    String?
  mapsLink        String?
  flyerImageUrl   String?
  hostName        String?
  guestMinister   String?
  contactPhone    String?
  contactEmail    String?
  contactWhatsapp String?
  status          EventStatus @default(DRAFT)
  featured        Boolean     @default(false)
  rsvpEnabled     Boolean     @default(true)
  capacity        Int?
  customPath      String?
  order           Int         @default(0)
  publishedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @default(now())
  Tenant          Tenant      @relation(fields: [tenantId], references: [id])
  Rsvps           EventRsvp[]

  @@unique([tenantId, slug])
  @@index([tenantId, status, startAt])
}

model EventRsvp {
  id          String    @id
  tenantId    String
  eventId     String
  fullName    String
  email       String
  phone       String?
  attendees   Int       @default(1)
  message     String?
  createdAt   DateTime  @default(now())
  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?
  Event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  Tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, eventId, createdAt])
}

/// Homepage content store. One row per section, content is a typed JSON blob
/// validated server-side by Zod (see src/site-settings/schemas).
model SiteSettings {
  id        String      @id
  tenantId  String
  section   SiteSection
  content   Json
  updatedAt DateTime    @default(now()) @updatedAt
  updatedBy String?
  Tenant    Tenant      @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, section])
}

// ── Public-site CMS ──────────────────────────────────────────────────────────
// Versioned, draft/publish content for the public website. Tenant-scoped in the
// service layer (@Roles + tenantId filter); RLS added as defense-in-depth via
// prisma/manual SQL. Rich content lives as a portable Tiptap JSON block array in
// ContentVersion.content — no normalized block table (keeps content portable and
// reads single-row). See CMS_ARCHITECTURE.md.

/// One editable public route per tenant. Points at the live published version.
model Page {
  id                 String           @id
  tenantId           String
  key                String // e.g. "home", "about", "about/beliefs", "give"
  title              String
  status             ContentStatus    @default(DRAFT)
  publishedVersionId String? // FK to the ContentVersion the public site reads
  cacheTag           String // ISR revalidation tag, mirrors the public route
  featureFlag        String? // e.g. "blog" — page hidden unless flag enabled
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @default(now()) @updatedAt
  updatedBy          String?
  Tenant             Tenant           @relation(fields: [tenantId], references: [id])
  Versions           ContentVersion[] @relation("PageVersions")
  PublishedVersion   ContentVersion?  @relation("PagePublished", fields: [publishedVersionId], references: [id])

  @@unique([tenantId, key])
  @@index([tenantId, status])
}

/// Immutable content snapshot. Drafts = newest non-published rows; history =
/// all rows. Rollback republishes any prior version.
model ContentVersion {
  id          String        @id
  tenantId    String
  pageId      String
  version     Int // monotonic per page
  content     Json // Tiptap JSON block array (validated by Zod)
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  publishedBy String?
  createdAt   DateTime      @default(now())
  createdBy   String?
  Tenant      Tenant        @relation(fields: [tenantId], references: [id])
  Page        Page          @relation("PageVersions", fields: [pageId], references: [id])
  PublishedOn Page[]        @relation("PagePublished")

  @@unique([pageId, version])
  @@index([tenantId, pageId])
}

/// R2-backed media. Stores the object key (never a public URL); the URL is
/// generated at read time from R2_PUBLIC_URL.
model MediaAsset {
  id         String   @id
  tenantId   String
  r2Key      String
  alt        String // required for accessibility
  mimeType   String
  sizeBytes  Int
  width      Int?
  height     Int?
  uploadedBy String?
  createdAt  DateTime @default(now())
  Tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

/// Site-wide settings singleton (one row per tenant): church identity, contact,
/// socials, footer. A form, not blocks — edited live (no draft/publish), audited.
model SiteConfig {
  id        String   @id
  tenantId  String   @unique
  content   Json
  updatedAt DateTime @default(now()) @updatedAt
  updatedBy String?
  Tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

/// Generic audit trail (create/update/publish/unpublish/delete). Platform-wide,
/// not CMS-only.
model AuditLog {
  id        String   @id
  tenantId  String
  actorId   String?
  action    String // CREATE | UPDATE | PUBLISH | UNPUBLISH | DELETE | ROLLBACK
  entity    String // e.g. "Page", "MediaAsset"
  entityId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
  Tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Unit {
  id           String       @id
  tenantId     String
  name         String
  description  String?
  departmentId String? // nullable: units can exist unassigned and the UI surfaces them
  createdAt    DateTime     @default(now())
  Tenant       Tenant       @relation(fields: [tenantId], references: [id])
  Department   Department?  @relation(fields: [departmentId], references: [id])
  UnitMember   UnitMember[]
  LeadAssignments UnitLeadAssignment[]
  FollowUpEntry   FollowUpEntry[]

  @@index([departmentId])
}

/// A church Administrative Structure (department). Service Units are grouped under
/// departments; each department is led by an Admin Head (see DepartmentHead).
/// Tenant-scoped in the service layer; RLS deny-all backstop via prisma/manual SQL.
model Department {
  id          String           @id
  tenantId    String
  code        String // e.g. OSM, MA, CI, FIN, DATA, WPC, GO
  name        String
  description String?
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
  Tenant      Tenant           @relation(fields: [tenantId], references: [id])
  Units       Unit[]
  Heads       DepartmentHead[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

/// History-preserving assignment of a user (Profile) as head of a department.
/// Replacing a head ends the current row (endedAt) and inserts a new one; a DB
/// partial unique index (endedAt IS NULL) enforces one active head per department.
model DepartmentHead {
  id           String     @id
  tenantId     String
  departmentId String
  userId       String // Profile.id of the head
  assignedById String? // Profile.id of the actor who assigned them
  assignedAt   DateTime   @default(now())
  endedAt      DateTime? // null = current head
  Tenant       Tenant     @relation(fields: [tenantId], references: [id])
  Department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  User         Profile    @relation("DepartmentHeadUser", fields: [userId], references: [id], onDelete: Cascade)
  AssignedBy   Profile?   @relation("DepartmentHeadAssignedBy", fields: [assignedById], references: [id])

  @@index([tenantId])
  @@index([departmentId])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model UnitMember {
  id          String   @id
  tenantId    String
  unitId      String
  memberId    String
  isLead      Boolean  @default(false)
  isAssistant Boolean  @default(false)
  joinedAt    DateTime @default(now())
  Member   Member   @relation(fields: [memberId], references: [id])
  Unit     Unit     @relation(fields: [unitId], references: [id])

  @@unique([unitId, memberId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Visitor {
  id                 String   @id
  tenantId           String
  firstName          String
  lastName           String
  email              String?
  phone              String?
  dateOfBirth        String?
  address            String?
  occupation         String?
  gender             String?
  howDidYouLearn     String?
  invitedBy          String?
  locatedInIbadan    Boolean?
  membershipInterest String?
  bornAgain          String?
  serviceExperience  String?
  prayerPoint        String?
  whatsappInterest   Boolean?
  submittedAt        DateTime @default(now())
  attendanceType     String?
  convertedAt         DateTime? // set once this visitor becomes a Member; hides them from the first-timers list
  convertedToMemberId String? // no FK; mirrors AuditLog.actorId — just an audit pointer
  Tenant             Tenant   @relation(fields: [tenantId], references: [id])
  FollowUpEntry      FollowUpEntry[]

  @@index([tenantId, convertedAt])
}

/// Featured "My Everlasting Hills Experience" stories shown on the public homepage slider.
/// Admin/PASTOR curates these — distinct from raw form-submission testimonies (which go
/// through FormSubmission with type='testimony' and are awaiting moderation).
model Testimonial {
  id             String    @id
  tenantId       String
  authorName     String
  authorRole     String?
  authorPhotoUrl String?
  content        String
  published      Boolean   @default(false)
  publishedAt    DateTime?
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())
  Tenant         Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, published, order])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Announcement {
  id          String       @id
  tenantId    String
  title       String
  body        String
  imageUrl    String?
  audience    String       @default("all")
  sendEmail   Boolean      @default(false)
  status      EventStatus  @default(PUBLISHED)
  createdById String?
  recipients  Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  Tenant      Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Household {
  id        String   @id
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  Tenant    Tenant   @relation(fields: [tenantId], references: [id])
  Member    Member[]

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Notification {
  id        String    @id
  tenantId  String
  profileId String
  type      String    @default("general")
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  Profile   Profile   @relation(fields: [profileId], references: [id])
  Tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@index([profileId, readAt])
}

enum EventStatus {
  DRAFT
  PUBLISHED
}

enum SiteSection {
  HERO
  ABOUT
  CULTURE
  SCRIPTURE
  SERVICE
  SERMONS
  COMMUNITY
  GIVING
  CONTACT
}

enum AlertType {
  ABSENCE
  AT_RISK
  BIRTHDAY
  ANNIVERSARY
  INACTIVE
  MILESTONE
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  DECEASED
  /// Set by a unit's team lead from the Follow-Up pipeline. Blocks login until restored.
  OPTED_OUT
}

enum CareAssignmentStatus {
  ACTIVE
  COMPLETED
}

enum HeadcountStatus {
  DRAFT
  CONFIRMED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InventoryStatus {
  IN_USE
  IN_STORAGE
  UNDER_REPAIR
  RETIRED
}

enum InventoryCondition {
  NEW
  GOOD
  FAIR
  POOR
}

enum InventoryHistoryType {
  NEW
  REPAIR
}

enum RepairStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum Role {
  SUPER_ADMIN
  PASTOR
  ADMIN
  ADMIN_HEAD
  HEAD_USHER
  UNIT_LEAD
  MEMBER
  VISITOR
}

enum SermonType {
  SINGLE
  SERIES
}

enum ServiceType {
  SUNDAY
  WEDNESDAY
  SPECIAL
}

enum SermonStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

model CommunityPost {
  id        String   @id
  tenantId  String
  profileId String
  text      String   @db.VarChar(500)
  reactions Int      @default(0)
  createdAt DateTime @default(now())
  Profile   Profile  @relation(fields: [profileId], references: [id])
  Tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

/// Discipleship course catalog, managed at /dashboard/admin/courses. A course can
/// require another course be completed (100% exam score) before it unlocks.
model Course {
  id             String    @id
  tenantId       String
  slug           String
  title          String
  tagline        String
  description    String
  category       String
  iconKey        String
  gradientFrom   String
  gradientTo     String
  duration       String
  instructorName String
  instructorRole String
  outcomes       String[]
  prerequisiteId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  Tenant        Tenant             @relation(fields: [tenantId], references: [id])
  Prerequisite  Course?            @relation("CoursePrerequisite", fields: [prerequisiteId], references: [id], onDelete: SetNull)
  UnlocksFor    Course[]           @relation("CoursePrerequisite")
  Modules       CourseModule[]
  ExamQuestions ExamQuestion[]
  Enrollments   CourseEnrollment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([prerequisiteId])
}

model CourseModule {
  id        String   @id
  tenantId  String
  courseId  String
  title     String
  sortOrder Int      @default(0)
  /// Optional single checkpoint question gating entry into the next module.
  /// checkCorrectIndex is never sent to members before they submit, same as ExamQuestion.
  checkQuestion     String?
  checkOptions      String[] @default([])
  checkCorrectIndex Int?

  Course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  Lessons CourseLesson[]

  @@index([courseId])
}

model CourseLesson {
  id        String  @id
  tenantId  String
  moduleId  String
  title     String
  duration  String
  videoUrl  String?
  sortOrder Int     @default(0)

  Module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
}

/// Options + correctIndex are never sent to members before they submit — the
/// backend grades exams server-side so the correct answer can't be read off the wire.
model ExamQuestion {
  id           String   @id
  tenantId     String
  courseId     String
  question     String
  options      String[]
  correctIndex Int
  sortOrder    Int      @default(0)

  Course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model CourseEnrollment {
  id           String    @id
  tenantId     String
  courseId     String
  memberId     String
  enrolledAt   DateTime  @default(now())
  completed    Boolean   @default(false)
  completedAt  DateTime?
  lastScorePct Int?
  attempts     Int       @default(0)
  /// CourseLesson ids the member has watched to completion (YouTube "ended" event).
  watchedLessonIds String[] @default([])
  /// CourseModule ids whose checkpoint question has been answered correctly.
  passedModuleIds  String[] @default([])

  Course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  Member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([courseId, memberId])
  @@index([tenantId])
  @@index([memberId])
}
