generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AttendanceRecord {
  id          String   @id
  memberId    String
  serviceId   String
  present     Boolean  @default(true)
  tenantId    String
  checkedInAt DateTime @default(now())
  markedBy    String?  @default("SELF")
  Member      Member   @relation(fields: [memberId], references: [id])
  Service     Service  @relation(fields: [serviceId], references: [id])
  Tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([memberId, serviceId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContactMessage {
  id       String   @id
  name     String
  email    String
  message  String
  sentAt   DateTime @default(now())
  tenantId String
  Tenant   Tenant   @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DiscussionQuestion {
  id                 String               @id
  tenantId           String
  sermonId           String
  question           String
  order              Int                  @default(0)
  createdAt          DateTime             @default(now())
  Sermon             Sermon               @relation(fields: [sermonId], references: [id])
  Tenant             Tenant               @relation(fields: [tenantId], references: [id])
  DiscussionResponse DiscussionResponse[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DiscussionResponse {
  id                 String             @id
  tenantId           String
  questionId         String
  memberId           String
  content            String
  createdAt          DateTime           @default(now())
  Member             Member             @relation(fields: [memberId], references: [id])
  DiscussionQuestion DiscussionQuestion @relation(fields: [questionId], references: [id])
  Tenant             Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([questionId, memberId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model EmailSubscriber {
  id           String   @id
  tenantId     String
  email        String
  subscribedAt DateTime @default(now())
  Tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model EngagementScore {
  id              String   @id
  tenantId        String
  memberId        String   @unique
  score           Int      @default(0)
  attendanceScore Int      @default(0)
  sermonScore     Int      @default(0)
  givingScore     Int      @default(0)
  communityScore  Int      @default(0)
  computedAt      DateTime @default(now())
  Member          Member   @relation(fields: [memberId], references: [id])
  Tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model FollowUpTask {
  id          String    @id
  tenantId    String
  memberId    String
  title       String
  dueDate     DateTime?
  done        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  Member      Member    @relation(fields: [memberId], references: [id])
  Tenant      Tenant    @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model FormSubmission {
  id          String   @id
  tenantId    String
  type        String
  data        Json
  submittedAt DateTime @default(now())
  Tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model GivingRecord {
  id             String    @id
  tenantId       String
  reference      String    @unique
  amount         Int
  currency       String    @default("NGN")
  donorName      String?
  donorEmail     String?
  category       String?
  paystackStatus String
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  Tenant         Tenant    @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ListenProgress {
  id          String   @id
  tenantId    String
  sermonId    String
  memberId    String
  positionSec Int      @default(0)
  completed   Boolean  @default(false)
  updatedAt   DateTime
  Member      Member   @relation(fields: [memberId], references: [id])
  Sermon      Sermon   @relation(fields: [sermonId], references: [id])
  Tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([sermonId, memberId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Member {
  id                 String               @id
  tenantId           String
  profileId          String               @unique
  firstName          String
  lastName           String
  email              String?
  phone              String?
  gender             String?
  dateOfBirth        DateTime?
  weddingAnniversary DateTime?
  instagram          String?
  facebook           String?
  twitter            String?
  linkedin           String?
  tiktok             String?
  address            String?
  joinedAt           DateTime             @default(now())
  bio                String?
  photoUrl           String?
  status             MemberStatus         @default(ACTIVE)
  notifyNewSermons   Boolean              @default(true)
  tags               String[]
  householdId        String?
  deactivationRequestedAt DateTime?
  AttendanceRecord   AttendanceRecord[]
  DiscussionResponse DiscussionResponse[]
  EngagementScore    EngagementScore?
  FollowUpTask       FollowUpTask[]
  ListenProgress     ListenProgress[]
  Household          Household?           @relation(fields: [householdId], references: [id])
  Profile            Profile              @relation(fields: [profileId], references: [id])
  Tenant             Tenant               @relation(fields: [tenantId], references: [id])
  PastorNote         PastorNote[]
  PastoralAlert      PastoralAlert[]
  SermonBookmark     SermonBookmark[]
  SermonComment      SermonComment[]
  SermonDirectMessageSent     SermonDirectMessage[] @relation("SermonDirectMessageSender")
  SermonDirectMessageReceived SermonDirectMessage[] @relation("SermonDirectMessageRecipient")
  SermonNote         SermonNote[]
  SermonReaction     SermonReaction[]
  UnitMember         UnitMember[]
  CareAsMember       CareAssignment[]     @relation("CareMember")
  CareAsLeader       CareAssignment[]     @relation("CareLeader")
  FollowUpAsSubject  FollowUpEntry[]      @relation("FollowUpSubjectMember")
  FollowUpAsAssignee FollowUpEntry[]      @relation("FollowUpAssignee")
  FollowUpLogs       FollowUpContactLog[] @relation("FollowUpLoggedBy")
  CourseEnrollment   CourseEnrollment[]
}

/// Care / discipleship assignment: a member shepherded by a leader (also a member).
model CareAssignment {
  id           String               @id
  tenantId     String
  memberId     String
  leaderId     String
  assignedById String?
  note         String?
  status       CareAssignmentStatus @default(ACTIVE)
  createdAt    DateTime             @default(now())
  Member       Member               @relation("CareMember", fields: [memberId], references: [id])
  Leader       Member               @relation("CareLeader", fields: [leaderId], references: [id])
  Tenant       Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, memberId, leaderId])
  @@index([tenantId, leaderId])
}

enum FollowUpStage {
  UNASSIGNED
  ASSIGNED
  IN_PROGRESS
  AWAITING_REVIEW
  CONFIRMED
  REOPENED
}

enum FollowUpSourceType {
  FIRST_TIMER
  ABSENTEE
}

enum FollowUpOutcome {
  BECAME_MEMBER
  RETURNED
  NOT_INTERESTED
  UNREACHABLE
  /// Below: the current outcome taxonomy shown in the "Log Outcome" form.
  REACHABLE
  TRAVEL
  CAME_FOR_VISITING
  HAVE_A_CHURCH
  WANT_TO_BE_MEMBER
}

enum FollowUpContactMethod {
  CALL
  SMS
  WHATSAPP
  VISIT
  OTHER
}

enum FollowUpContactOutcome {
  REACHED
  NO_ANSWER
  VOICEMAIL
  WRONG_NUMBER
  SCHEDULED_VISIT
}

/// A Unit's follow-up "Master List" row: a first-timer (Visitor) or absentee
/// (Member) tracked from first contact to confirmed follow-up. See
/// prisma/manual/2026-07-follow-up.sql for the hand-applied migration.
model FollowUpEntry {
  id            String                @id
  tenantId      String
  unitId        String
  sourceType    FollowUpSourceType
  memberId      String? // subject, when sourceType = ABSENTEE
  visitorId     String? // subject, when sourceType = FIRST_TIMER
  addedById     String // Profile.id of the usher/leader who added them
  assigneeId    String? // Member.id of the team member currently assigned
  stage         FollowUpStage         @default(UNASSIGNED)
  goalContacts  Int                   @default(3)
  contactCount  Int                   @default(0)
  lastContactAt DateTime?
  outcome       FollowUpOutcome?
  reviewNote    String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @default(now()) @updatedAt
  Tenant        Tenant                @relation(fields: [tenantId], references: [id])
  Unit          Unit                  @relation(fields: [unitId], references: [id])
  Member        Member?               @relation("FollowUpSubjectMember", fields: [memberId], references: [id])
  Visitor       Visitor?              @relation(fields: [visitorId], references: [id])
  Assignee      Member?               @relation("FollowUpAssignee", fields: [assigneeId], references: [id])
  AddedBy       Profile               @relation("FollowUpAddedBy", fields: [addedById], references: [id])
  Logs          FollowUpContactLog[]

  @@index([tenantId, unitId])
  @@index([tenantId, stage])
  @@index([assigneeId])
}

/// One logged contact attempt against a FollowUpEntry.
model FollowUpContactLog {
  id        String                 @id
  tenantId  String
  entryId   String
  byId      String // Member.id who logged it
  method    FollowUpContactMethod
  outcome   FollowUpContactOutcome
  note      String
  createdAt DateTime               @default(now())
  Entry     FollowUpEntry          @relation(fields: [entryId], references: [id], onDelete: Cascade)
  By        Member                 @relation("FollowUpLoggedBy", fields: [byId], references: [id])
  Tenant    Tenant                 @relation(fields: [tenantId], references: [id])

  @@index([entryId])
  @@index([tenantId])
}

/// A device/browser a user has logged in from before. Used to alert on logins
/// from new (previously unseen) devices.
model KnownDevice {
  id          String   @id
  tenantId    String
  userId      String
  fingerprint String
  userAgent   String?
  lastIp      String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  Tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([userId, fingerprint])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PastorNote {
  id        String   @id
  tenantId  String
  memberId  String
  content   String
  createdAt DateTime @default(now())
  Member    Member   @relation(fields: [memberId], references: [id])
