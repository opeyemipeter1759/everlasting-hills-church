model SermonComment {
  id        String          @id
  tenantId  String
  sermonId  String
  memberId  String
  parentId  String?
  content   String
  createdAt DateTime        @default(now())
  updatedAt DateTime
  Member    Member          @relation(fields: [memberId], references: [id])
  Sermon    Sermon          @relation(fields: [sermonId], references: [id])
  Tenant    Tenant          @relation(fields: [tenantId], references: [id])
  Parent    SermonComment?  @relation("SermonCommentReplies", fields: [parentId], references: [id])
  Replies   SermonComment[] @relation("SermonCommentReplies")

  @@index([sermonId])
