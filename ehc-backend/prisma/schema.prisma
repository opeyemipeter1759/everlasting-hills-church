generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AttendanceRecord {
  id          String   @id
  memberId    String
  serviceId   String
  present     Boolean  @default(true)
  tenantId    String
  checkedInAt DateTime @default(now())
  markedBy    String?  @default("SELF")
  Member      Member   @relation(fields: [memberId], references: [id])
  Service     Service  @relation(fields: [serviceId], references: [id])
  Tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([memberId, serviceId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ContactMessage {
  id       String   @id
  name     String
  email    String
  message  String
  sentAt   DateTime @default(now())
  tenantId String
  Tenant   Tenant   @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DiscussionQuestion {
  id                 String               @id
  tenantId           String
  sermonId           String
  question           String
  order              Int                  @default(0)
  createdAt          DateTime             @default(now())
  Sermon             Sermon               @relation(fields: [sermonId], references: [id])
  Tenant             Tenant               @relation(fields: [tenantId], references: [id])
  DiscussionResponse DiscussionResponse[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DiscussionResponse {
  id                 String             @id
  tenantId           String
  questionId         String
  memberId           String
  content            String
  createdAt          DateTime           @default(now())
  Member             Member             @relation(fields: [memberId], references: [id])
  DiscussionQuestion DiscussionQuestion @relation(fields: [questionId], references: [id])
  Tenant             Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([questionId, memberId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model EmailSubscriber {
  id           String   @id
  tenantId     String
  email        String
  subscribedAt DateTime @default(now())
  Tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model EngagementScore {
  id              String   @id
  tenantId        String
  memberId        String   @unique
  score           Int      @default(0)
  attendanceScore Int      @default(0)
  sermonScore     Int      @default(0)
  givingScore     Int      @default(0)
  communityScore  Int      @default(0)
  computedAt      DateTime @default(now())
  Member          Member   @relation(fields: [memberId], references: [id])
  Tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model FollowUpTask {
  id          String    @id
  tenantId    String
  memberId    String
  title       String
  dueDate     DateTime?
  done        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  Member      Member    @relation(fields: [memberId], references: [id])
  Tenant      Tenant    @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model FormSubmission {
  id          String   @id
  tenantId    String
  type        String
  data        Json
  submittedAt DateTime @default(now())
  Tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model GivingRecord {
  id             String    @id
  tenantId       String
  reference      String    @unique
  amount         Int
  currency       String    @default("NGN")
  donorName      String?
  donorEmail     String?
  category       String?
  paystackStatus String
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  Tenant         Tenant    @relation(fields: [tenantId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ListenProgress {
  id          String   @id
  tenantId    String
  sermonId    String
  memberId    String
  positionSec Int      @default(0)
  completed   Boolean  @default(false)
  updatedAt   DateTime
  Member      Member   @relation(fields: [memberId], references: [id])
  Sermon      Sermon   @relation(fields: [sermonId], references: [id])
  Tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([sermonId, memberId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Member {
  id                 String               @id
  tenantId           String
  profileId          String               @unique
  firstName          String
  lastName           String
  email              String?
  phone              String?
  gender             String?
  dateOfBirth        DateTime?
  weddingAnniversary DateTime?
  instagram          String?
  facebook           String?
  twitter            String?
  linkedin           String?
  tiktok             String?
  address            String?
  joinedAt           DateTime             @default(now())
  bio                String?
  photoUrl           String?
  status             MemberStatus         @default(ACTIVE)
  notifyNewSermons   Boolean              @default(true)
  tags               String[]
  householdId        String?
  deactivationRequestedAt DateTime?
  // Legacy social columns present in the DB — declared here to reconcile drift
  // (prevents prisma db push from dropping them). Not surfaced in the app yet.
  facebook           String?
  instagram          String?
  linkedin           String?
  twitter            String?
  tiktok             String?
  AttendanceRecord   AttendanceRecord[]
  DiscussionResponse DiscussionResponse[]
  EngagementScore    EngagementScore?
  FollowUpTask       FollowUpTask[]
  ListenProgress     ListenProgress[]
  Household          Household?           @relation(fields: [householdId], references: [id])
  Profile            Profile              @relation(fields: [profileId], references: [id])
  Tenant             Tenant               @relation(fields: [tenantId], references: [id])
  PastorNote         PastorNote[]
  PastoralAlert      PastoralAlert[]
  SermonBookmark     SermonBookmark[]
  SermonNote         SermonNote[]
  SermonReaction     SermonReaction[]
  UnitMember         UnitMember[]
  CareAsMember       CareAssignment[]     @relation("CareMember")
  CareAsLeader       CareAssignment[]     @relation("CareLeader")
}

/// Care / discipleship assignment: a member shepherded by a leader (also a member).
model CareAssignment {
  id           String               @id
  tenantId     String
  memberId     String
  leaderId     String
  assignedById String?
  note         String?
  status       CareAssignmentStatus @default(ACTIVE)
  createdAt    DateTime             @default(now())
  Member       Member               @relation("CareMember", fields: [memberId], references: [id])
  Leader       Member               @relation("CareLeader", fields: [leaderId], references: [id])
  Tenant       Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, memberId, leaderId])
  @@index([tenantId, leaderId])
}

/// A device/browser a user has logged in from before. Used to alert on logins
/// from new (previously unseen) devices.
model KnownDevice {
  id          String   @id
  tenantId    String
  userId      String
  fingerprint String
  userAgent   String?
  lastIp      String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  Tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([userId, fingerprint])
  @@index([userId])
}

