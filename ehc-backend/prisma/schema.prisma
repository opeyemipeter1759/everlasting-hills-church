/// A private note or question about a sermon sent directly to one other member (not visible
/// to anyone else, unlike SermonComment). Threaded via parentId so the recipient can reply.
model SermonDirectMessage {
  id          String                @id
  tenantId    String
  sermonId    String
  senderId    String
  recipientId String
  type        String
  content     String
  parentId    String?
  createdAt   DateTime              @default(now())
  readAt      DateTime?
  Sender      Member                @relation("SermonDirectMessageSender", fields: [senderId], references: [id])
  Recipient   Member                @relation("SermonDirectMessageRecipient", fields: [recipientId], references: [id])
  Sermon      Sermon                @relation(fields: [sermonId], references: [id])
  Tenant      Tenant                @relation(fields: [tenantId], references: [id])
  Parent      SermonDirectMessage?  @relation("SermonDirectMessageReplies", fields: [parentId], references: [id])
  Replies     SermonDirectMessage[] @relation("SermonDirectMessageReplies")

  @@index([sermonId])
  @@index([recipientId])
  @@index([senderId])
}

