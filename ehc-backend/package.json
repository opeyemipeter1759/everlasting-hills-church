    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.3",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.9",
