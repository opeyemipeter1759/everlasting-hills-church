generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  PASTOR
  ADMIN
  UNIT_LEAD
  MEMBER
  VISITOR
}

// ── Core ──────────────────────────────────────────────────────────────────────

model Tenant {
  id                String               @id @default(cuid())
  name              String
  slug              String               @unique
  createdAt         DateTime             @default(now())
  members           Member[]
  visitors          Visitor[]
  units             Unit[]
  services          Service[]
  sermons           Sermon[]
  givingRecords     GivingRecord[]
  prayerRequests    PrayerRequest[]
  formSubmissions   FormSubmission[]
  contactMessages   ContactMessage[]
  attendanceRecords AttendanceRecord[]
  roleAssignments   RoleAssignment[]
  webhookLogs       PaystackWebhookLog[]
}

model Profile {
  id              String           @id @default(cuid())
  userId          String           @unique // Supabase auth.users.id
  role            Role             @default(MEMBER)
  tenantId        String
  createdAt       DateTime         @default(now())
  member          Member?
  roleAssignments RoleAssignment[]
}

model RoleAssignment {
  id        String   @id @default(cuid())
  tenantId  String
  profileId String
  role      Role
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  profile   Profile  @relation(fields: [profileId], references: [id])

  @@unique([tenantId, profileId, role])
}

// ── People ────────────────────────────────────────────────────────────────────

model Member {
  id              String             @id @default(cuid())
  tenantId        String
  profileId       String             @unique
  firstName       String
  lastName        String
  email           String?
  phone           String?
  dateOfBirth     DateTime?
  address         String?
  joinedAt        DateTime           @default(now())
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  profile         Profile            @relation(fields: [profileId], references: [id])
  attendance      AttendanceRecord[]
  unitMemberships UnitMember[]
}

model Visitor {
  id                 String   @id @default(cuid())
  tenantId           String
  firstName          String
  lastName           String
  email              String?
  phone              String?
  dateOfBirth        String?
  address            String?
  occupation         String?
  gender             String?
  attendanceType     String?  // "In-Person" | "Online"
  howDidYouLearn     String?
  invitedBy          String?
  locatedInIbadan    Boolean?
  membershipInterest String?
  bornAgain          String?
  serviceExperience  String?
  prayerPoint        String?
  whatsappInterest   Boolean?
  submittedAt        DateTime @default(now())
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
}

// ── Units (departments/ministries) ────────────────────────────────────────────

model Unit {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  members     UnitMember[]
}

model UnitMember {
  id       String   @id @default(cuid())
  tenantId String
  unitId   String
  memberId String
  isLead   Boolean  @default(false)
  joinedAt DateTime @default(now())
  unit     Unit     @relation(fields: [unitId], references: [id])
  member   Member   @relation(fields: [memberId], references: [id])

  @@unique([unitId, memberId])
}

// ── Services & Attendance ─────────────────────────────────────────────────────

model Service {
  id          String             @id @default(cuid())
  tenantId    String
  name        String
  scheduledAt DateTime
  createdAt   DateTime           @default(now())
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  attendance  AttendanceRecord[]
}

model AttendanceRecord {
  id        String  @id @default(cuid())
  tenantId  String
  memberId  String
  serviceId String
  present   Boolean @default(true)
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  member    Member  @relation(fields: [memberId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@unique([memberId, serviceId])
}

// ── Forms & Submissions ───────────────────────────────────────────────────────

model FormSubmission {
  id          String   @id @default(cuid())
  tenantId    String
  type        String   // "prayer" | "testimony" | "question"
  data        Json
  submittedAt DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model PrayerRequest {
  id          String   @id @default(cuid())
  tenantId    String
  name        String?
  email       String?
  phone       String?
  request     String
  isAnonymous Boolean  @default(false)
  submittedAt DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model ContactMessage {
  id       String   @id @default(cuid())
  tenantId String
  name     String
  email    String
  message  String
  sentAt   DateTime @default(now())
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
}

// ── Content ───────────────────────────────────────────────────────────────────

model Sermon {
  id           String    @id @default(cuid())
  tenantId     String
  title        String
  speaker      String
  date         DateTime
  audioUrl     String?
  videoUrl     String?
  thumbnailUrl String?
  description  String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
}

// ── Giving ────────────────────────────────────────────────────────────────────

model GivingRecord {
  id             String    @id @default(cuid())
  tenantId       String
  reference      String    @unique
  amount         Int       // in kobo
  currency       String    @default("NGN")
  donorName      String?
  donorEmail     String?
  category       String?
  paystackStatus String
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
}

model PaystackWebhookLog {
  id          String   @id @default(cuid())
  tenantId    String
  event       String
  reference   String
  payload     Json
  processedAt DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}
