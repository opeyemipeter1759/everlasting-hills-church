generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum AlertType {
  ABSENCE
  AT_RISK
  BIRTHDAY
  ANNIVERSARY
  INACTIVE
  MILESTONE
}

enum Role {
  SUPER_ADMIN
  PASTOR
  ADMIN
  UNIT_LEAD
  MEMBER
  VISITOR
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  DECEASED
}

enum SermonStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

// ── Core ──────────────────────────────────────────────────────────────────────

model Tenant {
  id                String               @id @default(cuid())
  name              String
  slug              String               @unique
  createdAt         DateTime             @default(now())
  members           Member[]
  visitors          Visitor[]
  units             Unit[]
  services          Service[]
  sermons           Sermon[]
  givingRecords     GivingRecord[]
  prayerRequests    PrayerRequest[]
  formSubmissions   FormSubmission[]
  contactMessages   ContactMessage[]
  attendanceRecords AttendanceRecord[]
  roleAssignments   RoleAssignment[]
  webhookLogs       PaystackWebhookLog[]
  pastorNotes         PastorNote[]
  followUpTasks       FollowUpTask[]
  emailSubscribers    EmailSubscriber[]
  sermonReactions     SermonReaction[]
  sermonBookmarks     SermonBookmark[]
  sermonNotes         SermonNote[]
  listenProgress      ListenProgress[]
  discussionQuestions DiscussionQuestion[]
  discussionResponses DiscussionResponse[]
  engagementScores    EngagementScore[]
  pastoralAlerts      PastoralAlert[]
}

model Profile {
  id              String           @id @default(cuid())
  userId          String           @unique // Supabase auth.users.id
  role            Role             @default(MEMBER)
  tenantId        String
  createdAt       DateTime         @default(now())
  member          Member?
  roleAssignments RoleAssignment[]
}

model RoleAssignment {
  id        String   @id @default(cuid())
  tenantId  String
  profileId String
  role      Role
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  profile   Profile  @relation(fields: [profileId], references: [id])

  @@unique([tenantId, profileId, role])
}

// ── People ────────────────────────────────────────────────────────────────────

model Member {
  id              String             @id @default(cuid())
  tenantId        String
  profileId       String             @unique
  firstName       String
  lastName        String
  email           String?
  phone           String?
  dateOfBirth     DateTime?
  address         String?
  joinedAt        DateTime           @default(now())
  // Phase 2 fields
  status          MemberStatus       @default(ACTIVE)
  photoUrl        String?
  bio             String?
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  profile         Profile            @relation(fields: [profileId], references: [id])
  attendance      AttendanceRecord[]
  unitMemberships     UnitMember[]
  pastorNotes         PastorNote[]
  followUpTasks       FollowUpTask[]
  sermonReactions     SermonReaction[]
  sermonBookmarks     SermonBookmark[]
  sermonNotes         SermonNote[]
  listenProgress      ListenProgress[]
  discussionResponses DiscussionResponse[]
  notifyNewSermons    Boolean              @default(true)
  engagementScore     EngagementScore?
  pastoralAlerts      PastoralAlert[]
}

model Visitor {
  id                 String   @id @default(cuid())
  tenantId           String
  firstName          String
  lastName           String
  email              String?
  phone              String?
  dateOfBirth        String?
  address            String?
  occupation         String?
  gender             String?
  attendanceType     String?  // "In-Person" | "Online"
  howDidYouLearn     String?
  invitedBy          String?
  locatedInIbadan    Boolean?
  membershipInterest String?
  bornAgain          String?
  serviceExperience  String?
  prayerPoint        String?
  whatsappInterest   Boolean?
  submittedAt        DateTime @default(now())
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
}

// ── Units (departments/ministries) ────────────────────────────────────────────

model Unit {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime     @default(now())
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  members     UnitMember[]
}

model UnitMember {
  id       String   @id @default(cuid())
  tenantId String
  unitId   String
  memberId String
  isLead   Boolean  @default(false)
  joinedAt DateTime @default(now())
  unit     Unit     @relation(fields: [unitId], references: [id])
  member   Member   @relation(fields: [memberId], references: [id])

  @@unique([unitId, memberId])
}

// ── Services & Attendance ─────────────────────────────────────────────────────

model Service {
  id          String             @id @default(cuid())
  tenantId    String
  name        String
  scheduledAt DateTime
  createdAt   DateTime           @default(now())
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  attendance  AttendanceRecord[]
}

model AttendanceRecord {
  id        String  @id @default(cuid())
  tenantId  String
  memberId  String
  serviceId String
  present   Boolean @default(true)
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  member    Member  @relation(fields: [memberId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])

  @@unique([memberId, serviceId])
}

// ── Pastoral Tools ────────────────────────────────────────────────────────────

model PastorNote {
  id        String   @id @default(cuid())
  tenantId  String
  memberId  String
  content   String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  member    Member   @relation(fields: [memberId], references: [id])
}

model FollowUpTask {
  id          String    @id @default(cuid())
  tenantId    String
  memberId    String
  title       String
  dueDate     DateTime?
  done        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  member      Member    @relation(fields: [memberId], references: [id])
}

// ── Forms & Submissions ───────────────────────────────────────────────────────

model FormSubmission {
  id          String   @id @default(cuid())
  tenantId    String
  type        String   // "prayer" | "testimony" | "question"
  data        Json
  submittedAt DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model PrayerRequest {
  id          String   @id @default(cuid())
  tenantId    String
  name        String?
  email       String?
  phone       String?
  request     String
  isAnonymous Boolean  @default(false)
  submittedAt DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model ContactMessage {
  id       String   @id @default(cuid())
  tenantId String
  name     String
  email    String
  message  String
  sentAt   DateTime @default(now())
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
}

// ── Content ───────────────────────────────────────────────────────────────────

model Sermon {
  id            String        @id @default(cuid())
  tenantId      String
  title         String
  slug          String        @unique
  speaker       String
  date          DateTime
  audioUrl      String?
  audioKey      String?
  audioDuration Int?
  videoUrl      String?
  thumbnailUrl  String?
  description   String?
  transcript    String?
  scriptureRef  String?
  series        String?
  seriesSlug    String?
  tags          String[]
  status        SermonStatus  @default(DRAFT)
  isFeatured    Boolean       @default(false)
  playCount     Int           @default(0)
  scheduledFor  DateTime?
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  reactions     SermonReaction[]
  bookmarks     SermonBookmark[]
  notes         SermonNote[]
  progress      ListenProgress[]
  discussion    DiscussionQuestion[]
}

// ── Giving ────────────────────────────────────────────────────────────────────

model GivingRecord {
  id             String    @id @default(cuid())
  tenantId       String
  reference      String    @unique
  amount         Int       // in kobo
  currency       String    @default("NGN")
  donorName      String?
  donorEmail     String?
  category       String?
  paystackStatus String
  verifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
}

// ── Sermon Engagement ─────────────────────────────────────────────────────────

model SermonReaction {
  id        String   @id @default(cuid())
  tenantId  String
  sermonId  String
  memberId  String
  type      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  sermon    Sermon   @relation(fields: [sermonId], references: [id])
  member    Member   @relation(fields: [memberId], references: [id])

  @@unique([sermonId, memberId])
}

model SermonBookmark {
  id        String   @id @default(cuid())
  tenantId  String
  sermonId  String
  memberId  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  sermon    Sermon   @relation(fields: [sermonId], references: [id])
  member    Member   @relation(fields: [memberId], references: [id])

  @@unique([sermonId, memberId])
}

model SermonNote {
  id        String   @id @default(cuid())
  tenantId  String
  sermonId  String
  memberId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  sermon    Sermon   @relation(fields: [sermonId], references: [id])
  member    Member   @relation(fields: [memberId], references: [id])

  @@unique([sermonId, memberId])
}

model ListenProgress {
  id          String   @id @default(cuid())
  tenantId    String
  sermonId    String
  memberId    String
  positionSec Int      @default(0)
  completed   Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  sermon      Sermon   @relation(fields: [sermonId], references: [id])
  member      Member   @relation(fields: [memberId], references: [id])

  @@unique([sermonId, memberId])
}

model EmailSubscriber {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  subscribedAt DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
}

model DiscussionQuestion {
  id        String               @id @default(cuid())
  tenantId  String
  sermonId  String
  question  String
  order     Int                  @default(0)
  createdAt DateTime             @default(now())
  tenant    Tenant               @relation(fields: [tenantId], references: [id])
  sermon    Sermon               @relation(fields: [sermonId], references: [id])
  responses DiscussionResponse[]
}

model DiscussionResponse {
  id         String             @id @default(cuid())
  tenantId   String
  questionId String
  memberId   String
  content    String
  createdAt  DateTime           @default(now())
  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  question   DiscussionQuestion @relation(fields: [questionId], references: [id])
  member     Member             @relation(fields: [memberId], references: [id])

  @@unique([questionId, memberId])
}

// ── Analytics ─────────────────────────────────────────────────────────────────

model EngagementScore {
  id              String   @id @default(cuid())
  tenantId        String
  memberId        String   @unique
  score           Int      @default(0)
  attendanceScore Int      @default(0)
  sermonScore     Int      @default(0)
  givingScore     Int      @default(0)
  communityScore  Int      @default(0)
  computedAt      DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  member          Member   @relation(fields: [memberId], references: [id])
}

model PastoralAlert {
  id         String    @id @default(cuid())
  tenantId   String
  memberId   String
  type       AlertType
  message    String
  isRead     Boolean   @default(false)
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  member     Member    @relation(fields: [memberId], references: [id])
}

// ── Giving ────────────────────────────────────────────────────────────────────

model PaystackWebhookLog {
  id          String   @id @default(cuid())
  tenantId    String
  event       String
  reference   String
  payload     Json
  processedAt DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}
