# ── Resend (transactional email) ─────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address that receives contact form submissions
CONTACT_EMAIL=hello@everlastinghills.org

# The "from" address used in outbound emails.
# Must be a verified domain in Resend. During development you can use:
#   onboarding@resend.dev  (Resend's sandbox — works without domain verification)
# For production, set up your domain at https://resend.com/domains and use:
#   noreply@yourdomain.com
RESEND_FROM=onboarding@resend.dev

# ── Supabase (database + auth) ────────────────────────────────────────────────
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyxxxxxxxxxxxx

# Direct connection URL for Prisma migrations (bypasses Supabase connection pooler)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
