# ──────────────────────────────────────────────────────────────────────────────
# Frontend production env (Vercel / any Node host)
# NEXT_PUBLIC_* variables are inlined into the browser bundle at BUILD time.
# Variables WITHOUT the prefix are only available server-side (middleware, Server Components).
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend API (where the Next.js app talks to NestJS) ───────────────────────
# Used by both browser-side axios and server-side fetches.
NEXT_PUBLIC_API_BASE_URL=https://ehc-backend.up.railway.app

# ── Public app URL (drives robots.txt + sitemap.xml + canonical URLs) ─────────
NEXT_PUBLIC_APP_URL=https://everlastinghills.org

# ── Supabase ──────────────────────────────────────────────────────────────────
# Used by middleware (JWKS verification) and the SSR Supabase client.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Server-side only — for admin operations from Server Components (member CRUD, etc.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Database (Prisma uses this from Next.js Server Components / route handlers) ──
DATABASE_URL=postgresql://USER:PASS@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20
DIRECT_URL=postgresql://USER:PASS@HOST.pooler.supabase.com:5432/postgres

# ── Resend (sermon notification emails sent from Next.js cron handlers, if any) ──
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=hello@everlastinghills.org
RESEND_ADMIN_EMAIL=admin@everlastinghills.org
CONTACT_EMAIL=contact@everlastinghills.org

# ── Tenant ────────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=ehc_xxxxxxxxxxxxxxxxxxxx

# ── Cloudflare R2 (sermon audio storage) ──────────────────────────────────────
R2_ACCOUNT_ID=YOUR_R2_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=ehc-sermons
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
